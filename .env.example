# Environment Settings
PROJECT_NAME="Enterprise AI Document Assistant"
ENV="development"

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=enterprise_doc_db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/enterprise_doc_db
SYNC_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/enterprise_doc_db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0

# Authentication & Security
JWT_SECRET_KEY=super-secret-jwt-key-for-enterprise-doc-assistant-2026-secure-key
JWT_REFRESH_SECRET_KEY=super-secret-refresh-key-for-enterprise-doc-assistant-2026
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# AI APIs
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Vector Store & Storage
VECTOR_STORE_TYPE=chroma # 'chroma' or 'pinecone'
CHROMA_PERSIST_DIR=./backend/chroma_data
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=us-east-1

STORAGE_DIR=./backend/storage

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
